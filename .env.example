# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Optional: Admin Telegram user IDs (comma-separated)
ADMIN_IDS=

# Optional: Download directory
DOWNLOAD_DIR=/tmp/scribd_downloads

# Optional: Scribd cookies file for authenticated downloads
COOKIES_PATH=

# Optional: Rate limit between requests (seconds)
RATE_LIMIT_SECONDS=30

# Optional: Max queue size
MAX_QUEUE_SIZE=10

# Optional: API server port
API_PORT=8000
