# Scribd Downloader Bot Configuration

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TOKEN_HERE

# Admin Telegram user IDs (comma-separated, optional)
ADMIN_IDS=

# Download directory
DOWNLOAD_DIR=/tmp/scribd_downloads

# Database path
DB_PATH=/opt/scribd-bot/scribd_bot.db

# Scribd cookies (optional, for subscriber-only content)
COOKIES_PATH=

# Rate limit between requests (seconds)
RATE_LIMIT_SECONDS=30

# Max queue size
MAX_QUEUE_SIZE=10

# Web server port
WEB_PORT=8000

# Max concurrent downloads
MAX_CONCURRENT_DOWNLOADS=2
